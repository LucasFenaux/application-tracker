{
  "name": "application-tracker",
  "version": "0.1.0",
  "private": true,
  "bin": ".next/standalone/server.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=16384' next dev",
    "build": "next build",
    "build:binary": "node scripts/build-binary.js",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.18",
    "better-sqlite3": "^12.11.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.61.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "pkg": "^5.8.1",
    "typescript": "^5"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  },
  "pkg": {
    "scripts": [
      ".next/standalone/**/*.js"
    ],
    "assets": [
      ".next/standalone/public/**/*",
      ".next/standalone/.next/**/*",
      "node_modules/better-sqlite3/build/Release/better_sqlite3.node",
      "node_modules/@xenova/transformers/**/*"
    ]
  }
