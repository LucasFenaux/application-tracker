{
  "manifest_version": 3,
  "name": "AppTracker Job Saver",
  "version": "1.25",
  "description": "Save jobs to your Application Tracker directly from any job board.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to AppTracker"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["modal.css"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "apptracker@localhost.com"
    }
  }
}
